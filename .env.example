# AI 設定 (預設 gemini, 可選: gemini, openai, ollama, claude, deepseek, mistral, groq, openrouter, kimi, qwen)
AI_PROVIDER=gemini

# AI API Keys
GOOGLE_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
MOONSHOT_API_KEY=
DASHSCOPE_API_KEY=

# Google Drive (NotebookLM 同步用)
# 請將 credentials.json 放在專案根目錄，並在 docker-compose.yml 解除註解
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials.json
NOTEBOOKLM_SOURCE_FOLDER_ID=

# Slack 設定
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...

# Obsidian 設定
OBSIDIAN_VAULT_PATH=/app/obsidian_vault
